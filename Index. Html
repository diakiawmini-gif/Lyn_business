  ];

  const statuses = [
    { client: 'Juan D.',  design: 'Online Store Pro',    badgeClass: 'badge-deal',     status: 'Deal Closed ✓', msg: 'Project started — delivery in 2 weeks' },
    { client: 'Maria S.', design: 'Corporate Business',  badgeClass: 'badge-progress', status: 'In Progress',   msg: 'Design mockups sent to client' },
    { client: 'Pedro R.', design: 'Landing Page',        badgeClass: 'badge-pending',  status: 'Pending Review',msg: 'Awaiting owner approval' },
    { client: 'Ana L.',   design: 'Food & Restaurant',   badgeClass: 'badge-deal',     status: 'Deal Closed ✓', msg: 'Final site delivered and launched' }
  ];

  let currentDesign = null;

  // ---- RENDER DESIGNS ----
  function renderDesigns(filter) {
    const grid = document.getElementById('designsGrid');
    const list = filter === 'all' ? designs : designs.filter(d => d.cat === filter);

    grid.innerHTML = list.map(d => `
      <div class="design-card reveal" onclick="openModal(${d.id})" data-cat="${d.cat}">
        <div class="card-thumb" style="background:${d.bg}">
          <span style="font-size:52px;">${d.icon}</span>
          ${d.badge ? `<div style="position:absolute;top:12px;right:12px;background:var(--gold);color:#000;font-size:11px;font-weight:700;padding:4px 10px;border-radius:50px;">${d.badge}</div>` : ''}
